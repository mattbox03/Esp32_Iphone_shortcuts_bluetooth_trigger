# ============================================================
#  ESP32 BT Trigger + Find My - DUAL MODE (Classic BT + BLE)
# ============================================================

# Bluetooth enabled, DUAL mode (BR/EDR + BLE together)
CONFIG_BT_ENABLED=y
CONFIG_BTDM_CTRL_MODE_BTDM=y
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=n
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=n

# Bluedroid host: Classic + HID Device (the trigger) AND BLE (the Find My beacon)
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_CLASSIC_ENABLED=y
CONFIG_BT_HID_ENABLED=y
CONFIG_BT_HID_DEVICE_ENABLED=y
CONFIG_BT_HID_HOST_ENABLED=n
CONFIG_BT_BLE_ENABLED=y

# Bigger app partition: the dual-mode BT stack does not fit in 1 MB
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# 4 MB flash (typical on the Wemos D1 mini ESP32)
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
